APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
DOMAIN=localhost

APP_PORT=8080
VITE_PORT=5173
VITE_HMR_HOST=localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=app
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Mailpit dev mail viewer — http://localhost:${MAILPIT_UI_PORT:-8025}
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

# Billing — Phase 3 (Stripe). PayPal + regional gateways added in Phase 3.2-3.4.
BILLING_DEFAULT_CURRENCY=USD
BILLING_DEFAULT_GATEWAY=stripe
BILLING_TRIAL_DAYS=14

# Stripe (Global) — shipped driver
STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE=300
STRIPE_API_VERSION="2024-11-20.acacia"
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PORTAL_RETURN_PATH=/
STRIPE_CHECKOUT_SUCCESS_PATH=/
STRIPE_CHECKOUT_CANCEL_PATH=/

# PayPal (Global, planned)
PAYPAL_ENABLED=false
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Paymob (EG/AE/SA/OM/PK, planned)
PAYMOB_ENABLED=false
PAYMOB_REGION=eg
PAYMOB_SECRET_KEY=
PAYMOB_PUBLIC_KEY=
PAYMOB_API_KEY=
PAYMOB_HMAC_SECRET=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_IFRAME_ID=

# Fawry (Egypt, planned)
FAWRY_ENABLED=false
FAWRY_ENVIRONMENT=staging
FAWRY_MERCHANT_CODE=
FAWRY_SECURE_KEY=

# PayTabs (MENA + GCC + Morocco + Global UK, planned)
PAYTABS_ENABLED=false
PAYTABS_REGION=SAU
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_CLIENT_KEY=

# Geidea (EG/SA/AE, planned)
GEIDEA_ENABLED=false
GEIDEA_ENVIRONMENT=sandbox
GEIDEA_PUBLIC_KEY=
GEIDEA_API_PASSWORD=

# Amazon Payment Services / Payfort (MENA, planned)
APS_ENABLED=false
APS_ENVIRONMENT=sandbox
APS_MERCHANT_IDENTIFIER=
APS_ACCESS_CODE=
APS_SHA_REQUEST_PHRASE=
APS_SHA_RESPONSE_PHRASE=
APS_SHA_TYPE=sha256

# Telr (AE/SA/JO/BH, planned)
TELR_ENABLED=false
TELR_TEST_MODE=1
TELR_STORE_ID=
TELR_AUTH_KEY=
TELR_IPN_SECRET=

# HyperPay (SA/AE/JO/EG, planned)
HYPERPAY_ENABLED=false
HYPERPAY_ENVIRONMENT=test
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID_CARD=
HYPERPAY_ENTITY_ID_MADA=
HYPERPAY_ENTITY_ID_APPLEPAY=
HYPERPAY_WEBHOOK_SECRET=

# MyFatoorah (KW/SA/AE/BH/OM/QA/JO/EG, planned)
MYFATOORAH_ENABLED=false
MYFATOORAH_ENVIRONMENT=test
MYFATOORAH_COUNTRY=kuwait
MYFATOORAH_API_TOKEN=
MYFATOORAH_WEBHOOK_SECRET=

# HitPay (SG/MY/AU/HK/PH, planned)
HITPAY_ENABLED=false
HITPAY_MODE=sandbox
HITPAY_API_KEY=
HITPAY_SALT=
HITPAY_PLATFORM_KEY=

# Billplz (Malaysia, planned)
BILLPLZ_ENABLED=false
BILLPLZ_SANDBOX=true
BILLPLZ_API_KEY=
BILLPLZ_COLLECTION_ID=
BILLPLZ_X_SIGNATURE_KEY=

# iPay88 (MY/SG/ID/PH/TH/VN, planned)
IPAY88_ENABLED=false
IPAY88_ENVIRONMENT=sandbox
IPAY88_COUNTRY=MY
IPAY88_MERCHANT_CODE=
IPAY88_MERCHANT_KEY=
IPAY88_SIGNATURE_TYPE=HMACSHA512

# Sentry — env-gated. Set SENTRY_DSN to enable error reporting.
SENTRY_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false

# API
API_RATE_LIMIT_PER_MINUTE=60
SCRIBE_AUTH_KEY=

# Notifications — optional channels
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
LOG_SLACK_WEBHOOK_URL=

# Transactional mail providers (alternatives to MAIL_MAILER=smtp)
RESEND_API_KEY=
POSTMARK_API_KEY=

VITE_APP_NAME="${APP_NAME}"
